# Public URL of your HookPilot instance (no trailing slash)
BASE_URL=http://localhost:8000

# Optional: Telegram bot token for webhook notifications
# Get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Database path (inside the container, mapped via volume)
DATABASE_PATH=./data/hookpilot.db

# How many days to keep requests (0 = forever)
REQUEST_RETENTION_DAYS=30

# Max requests stored per bucket (oldest are deleted when exceeded)
MAX_REQUESTS_PER_BUCKET=500

# Max incoming body size in bytes (default: 524288 = 512 KB)
MAX_BODY_SIZE=524288

# ── AI (optional) ─────────────────────────────────────────────────────────
# Set AI_MODEL to enable the "Explain" and "Generate handler" features.
# Uses LiteLLM — supports any provider below (and 100+ more).
# Leave blank to disable AI features entirely.

AI_MODEL=

# ── Provider API keys — set whichever matches your AI_MODEL ───────────────

# OpenAI  (AI_MODEL examples: gpt-4o-mini  |  gpt-4o  |  gpt-3.5-turbo)
OPENAI_API_KEY=

# Anthropic  (AI_MODEL examples: claude-haiku-3-5-20251001  |  claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Google Gemini  (AI_MODEL examples: gemini/gemini-2.0-flash  |  gemini/gemini-1.5-pro)
GEMINI_API_KEY=

# Groq — fast & free tier  (AI_MODEL examples: groq/llama-3.1-8b-instant  |  groq/mixtral-8x7b-32768)
GROQ_API_KEY=

# Mistral  (AI_MODEL examples: mistral/mistral-small-latest  |  mistral/mistral-large-latest)
MISTRAL_API_KEY=

# Cohere  (AI_MODEL examples: command-r  |  command-r-plus)
COHERE_API_KEY=

# Together AI  (AI_MODEL examples: together_ai/meta-llama/Llama-3-8b-chat-hf)
TOGETHER_API_KEY=

# Azure OpenAI  (AI_MODEL example: azure/gpt-4o)
# AZURE_API_KEY=
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-01

# Ollama — local models, no key needed  (AI_MODEL examples: ollama/llama3  |  ollama/mistral)
# Just make sure Ollama is running on the same host.
# OLLAMA_API_BASE=http://localhost:11434  (only needed if non-default)
